{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "linc",
  "version": "0.1.0",
  "identifier": "com.zen-zai.linc",
  "build": {
    "frontendDist": "http://localhost:3001",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "linc",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/server"
    ],
    "resources": {
      "../dist/": "frontend/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
