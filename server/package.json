{
  "name": "linc-server",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch index.js",
    "start": "node index.js",
    "build:sidecar": "esbuild index.js --bundle --platform=node --format=cjs --outfile=/tmp/server-bundle.cjs && pkg /tmp/server-bundle.cjs --target node20-macos-arm64 --output ../client/src-tauri/binaries/server-aarch64-apple-darwin"
  },
  "dependencies": {
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "glob": "^11.0.0",
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1",
    "esbuild": "^0.25.12",
    "pkg": "^5.8.1"
  }
}
